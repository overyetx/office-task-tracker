<Application x:Class="OfficeTaskTracker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Global dark theme styles -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="#0f0f1a"/>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Global TextBox placeholder style -->
        <Style TargetType="TextBox" x:Key="DarkTextBox">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#00D4AA"/>
        </Style>
    </Application.Resources>
</Application>

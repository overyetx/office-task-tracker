                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" CornerRadius="20" Padding="20,10"
                                                    Background="#0f3460" Cursor="Hand">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════ Progress bar ══════ -->
        <Border Grid.Row="1" Background="#16213e" CornerRadius="10" Padding="16,10" Margin="0,0,0,12">
            <StackPanel>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="Completion" Foreground="#888" FontSize="11" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="ProgressText" HorizontalAlignment="Right"
                               Foreground="#00D4AA" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                </DockPanel>
                <Border Height="5" CornerRadius="3" Background="#0a0a18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ProgressColumn" Width="0*"/>
                            <ColumnDefinition x:Name="RemainingColumn" Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="5" CornerRadius="3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00D4AA" Offset="0"/>
                                    <GradientStop Color="#00B894" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══════ Task Cards Grid ══════ -->
        <ItemsControl x:Name="TaskCardsControl" Grid.Row="2">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="4" CornerRadius="10" Cursor="Hand"
                            MouseLeftButtonDown="TaskCard_Click"
                            Tag="{Binding}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#16213e"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="Background" Value="#0d2a2a"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid Margin="14,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Task number badge: "GÖREV 1" -->
                            <Border Grid.Row="0" HorizontalAlignment="Left" CornerRadius="4" Padding="8,3" Margin="0,0,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#0f3460"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Background" Value="#0a4a3a"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4488CC"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="Foreground" Value="#00D4AA"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Task name: "Send a parcel" -->
                            <TextBlock Grid.Row="1" Text="{Binding Name}" 
                                       TextWrapping="Wrap" FontSize="13"
                                       FontFamily="Segoe UI" 
                                       VerticalAlignment="Top"
                                       Margin="0,0,0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E0E0E0"/>
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Foreground" Value="#55887788"/>
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Task price -->
                            <TextBlock Grid.Row="1" Text="{Binding PriceText}" 
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#00D4AA" FontFamily="Segoe UI"
                                       VerticalAlignment="Bottom" Margin="0,4,0,0"/>

                            <!-- Toggle switch -->
                            <Grid Grid.Row="2" HorizontalAlignment="Left" Margin="0,6,0,0">
                                <Border Width="44" Height="24" CornerRadius="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2a2a3e"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#00D4AA" Offset="0"/>
                                                                <GradientStop Color="#00B894" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border Width="18" Height="18" CornerRadius="9" Margin="2,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#555"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Background" Value="White"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
                </Border>
            </Grid>

            <!-- ══════ MODAL OVERLAY (Monthly Report) ══════ -->
            <Grid x:Name="MonthlyReportModal" Grid.RowSpan="2" Visibility="Collapsed" Panel.ZIndex="101">
                <Border Background="#D8000000" MouseLeftButtonDown="ReportModalDim_Click"/>
                <Border CornerRadius="12" Background="#0f0f1a" BorderThickness="1" BorderBrush="#1a2745"
                        Width="800" Height="550" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="5" Color="Black" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid Margin="24">

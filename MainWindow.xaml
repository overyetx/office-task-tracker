<Window x:Class="OfficeTaskTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:OfficeTaskTracker.Converters"
        Title="Office Task Tracker"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToPaymentStatusConverter x:Key="PaymentStatusConverter"/>
        <converters:BoolToPaymentColorConverter x:Key="PaymentColorConverter"/>
        <converters:BoolToCompletionStatusConverter x:Key="CompletionStatusConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Custom DataGrid Style -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#16213e"/>
            <Setter Property="AlternatingRowBackground" Value="#1a2745"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2a3555"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="DarkColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="#00D4AA"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#1a4a7a"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1f3a6e"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1f2b4d"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1f3a6e"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Custom ComboBox Style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1f2b4d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2a3555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          Background="{TemplateBinding Background}" 
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Padding="{TemplateBinding Padding}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Name="Border" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="24" />
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" Grid.Column="1" Fill="#888" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#2f3b5d"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Name="DropDownBorder" Background="#16213e" BorderThickness="1" BorderBrush="#2a3555" CornerRadius="4"/>
                                    <ScrollViewer Margin="0,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2a3555"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#00D4AA"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0f0f1a" CornerRadius="12" BorderThickness="1" BorderBrush="#1a2745">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom TitleBar -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown" Panel.ZIndex="1000">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="Segoe UI Emoji" Foreground="White"/>
                    <TextBlock x:Name="AppTitleText1" Text="Office Task Tracker" FontSize="12" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,16,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Width="44" Background="Transparent" BorderThickness="0" Foreground="#AAA" Cursor="Hand" Click="MinimizeWindow_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="0,11,0,0" Margin="0" Padding="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#2a2a3e"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕" Width="44" Background="Transparent" BorderThickness="0" Foreground="#AAA" Cursor="Hand" Click="CloseWindow_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="0,11,0,0" Margin="0" Padding="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content Container (Row 1) -->
            <Grid Grid.Row="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════ HEADER BAR ═══════════════════ -->
        <Border Grid.Row="0" Padding="24,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#16213e" Offset="0"/>
                    <GradientStop Color="#1a1a2e" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="📋" FontSize="26" VerticalAlignment="Center" Margin="0,0,10,0" FontFamily="Segoe UI Emoji" Foreground="White"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="AppTitleText2" Text="Office Task Tracker" FontSize="20" FontWeight="Bold" 
                                   Foreground="White" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                        <TextBlock Text="Task tracking and management system" FontSize="11" 
                                   Foreground="#aaa" FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ScreenshotBtn" Content="📸 Take Screenshot" 
                            Click="TakeScreenshot_Click"
                            Cursor="Hand" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" CornerRadius="8" Padding="16,10"
                                                    Cursor="Hand">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#00D4AA" Offset="0"/>
                                                        <GradientStop Color="#00B894" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#1a1a2e"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="ManualAddBtn" Content="＋ Add Manually"
                            Click="ManualAdd_Click"
                            Cursor="Hand" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" CornerRadius="8" Padding="16,10"
                                                    Background="#1f3a6e" Cursor="Hand">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#2a4b8a"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#102544"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="MonthlyReportBtn" Content="📊 Monthly Summary"
                            Click="MonthlyReport_Click"
                            Cursor="Hand" Margin="0,0,20,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" CornerRadius="8" Padding="16,10"
                                                    Background="#2d1f4a" Cursor="Hand">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#432c70"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#1d1330"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Backup Group -->
                    <Border Background="#16213e" CornerRadius="8" Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="📤 EXPORT" Click="ExportBackup_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#888"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#252f4a"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Rectangle Width="1" Fill="#2a3555" Margin="4,6"/>
                            <Button Content="📥 IMPORT" Click="ImportBackup_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#888"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#252f4a"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
        <Grid Grid.Row="1" Margin="24,16,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Stats Cards -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Earnings -->
                <Border Grid.Column="0" Background="#16213e" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Task Earnings" Foreground="#888" FontSize="11" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TotalEarningsText" Text="$0" 
                                   Foreground="White" FontSize="24" FontWeight="Bold" 
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        <TextBlock x:Name="TotalSessionsText" Text="0 contracts" 
                                   Foreground="#555" FontSize="11" 
                                   FontFamily="Segoe UI" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Unpaid Amount -->
                <Border Grid.Column="2" CornerRadius="12" Padding="18,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2a1a1a" Offset="0"/>
                            <GradientStop Color="#1a1a2e" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="Unpaid Bonus" Foreground="#FF6363" FontSize="11" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="UnpaidAmountText" Text="$0" 
                                   Foreground="#FF6363" FontSize="24" FontWeight="Bold" 
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        <TextBlock x:Name="UnpaidText" Text="0 contracts" 
                                   Foreground="#663333" FontSize="11" 
                                   FontFamily="Segoe UI" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Paid Amount -->
                <Border Grid.Column="4" CornerRadius="12" Padding="18,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1a2a2a" Offset="0"/>
                            <GradientStop Color="#1a1a2e" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="Paid Bonus" Foreground="#00D4AA" FontSize="11" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="PaidAmountText" Text="$0" 
                                   Foreground="#00D4AA" FontSize="24" FontWeight="Bold" 
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        <TextBlock x:Name="PaidText" Text="0 contracts" 
                                   Foreground="#336655" FontSize="11" 
                                   FontFamily="Segoe UI" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Tasks -->
                <Border Grid.Column="6" Background="#16213e" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Completed" Foreground="#888" FontSize="11" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TotalTasksText" Text="0" 
                                   Foreground="White" FontSize="24" FontWeight="Bold" 
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        <TextBlock Text="$10,000 / task" 
                                   Foreground="#555" FontSize="11" 
                                   FontFamily="Segoe UI" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Completed Tasks -->
                <Border Grid.Column="8" Background="#16213e" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Total Tasks" Foreground="#888" FontSize="11" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="CompletedTasksText" Text="0" 
                                   Foreground="#00D4AA" FontSize="24" FontWeight="Bold" 
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        <TextBlock x:Name="CompletedPercentText" Text="%0" 
                                   Foreground="#336655" FontSize="11" 
                                   FontFamily="Segoe UI" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Filter / Search Bar -->
            <Border Grid.Row="1" Background="#16213e" CornerRadius="10" Padding="16,10" Margin="0,0,0,16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Filter by Date:" Foreground="#888" FontSize="13" 
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        
                        <ComboBox x:Name="YearComboBox" Style="{StaticResource DarkComboBox}" Width="80" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>
                        <ComboBox x:Name="MonthComboBox" Style="{StaticResource DarkComboBox}" Width="110" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>
                        <ComboBox x:Name="DayComboBox" Style="{StaticResource DarkComboBox}" Width="70" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>

                        <!-- Clear Date Button -->
                        <Button Content="✕" Click="ClearDateFilter_Click" 
                                Cursor="Hand" ToolTip="Clear date filter"
                                VerticalAlignment="Center"
                                Width="24" Height="24"
                                Background="Transparent" Foreground="#888" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" CornerRadius="12" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Border Width="1" Background="#2a3555" Margin="20,4"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Filter buttons -->
                        <RadioButton x:Name="FilterAll" Content="All" GroupName="Filter" 
                                     IsChecked="True" Checked="Filter_Changed"
                                     Foreground="#AAA" FontSize="13" Cursor="Hand"
                                     FontFamily="Segoe UI" Margin="0,0,24,0">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="border" CornerRadius="6" Padding="12,6"
                                                        Background="Transparent" Cursor="Hand">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#0f3460"/>
                                                        <Setter Property="Foreground" Value="#00D4AA"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#1a2745"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>

                        <RadioButton x:Name="FilterUnpaid" Content="Unpaid" GroupName="Filter"
                                     Checked="Filter_Changed"
                                     Foreground="#AAA" FontSize="13" Cursor="Hand"

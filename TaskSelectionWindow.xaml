<Window x:Class="OfficeTaskTracker.TaskSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Selection"
        Width="850" Height="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#1a1a2e" CornerRadius="12" BorderThickness="1" BorderBrush="#2a3555">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom TitleBar -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown" Panel.ZIndex="1000">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="📝" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="Segoe UI Emoji" Foreground="White"/>
                    <TextBlock Text="Task Selection" FontSize="12" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Width="44" Background="Transparent" BorderThickness="0" Foreground="#AAA" Cursor="Hand" Click="MinimizeWindow_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="0,11,0,0" Margin="0" Padding="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#2a2a3e"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕" Width="44" Background="Transparent" BorderThickness="0" Foreground="#AAA" Cursor="Hand" Click="CloseWindow_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="0,11,0,0" Margin="0" Padding="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1" Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📝 Task Selection" FontSize="22" FontWeight="Bold" 
                       Foreground="White" FontFamily="Segoe UI"/>
            <TextBlock x:Name="SubtitleText" Text="Select or edit tasks detected via OCR"
                       FontSize="12" Foreground="#888" FontFamily="Segoe UI" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Session info (Office/Player) -->
        <Border Grid.Row="1" Background="#16213e" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="CONTRACT" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="ContractInput" Background="#0f3460" Foreground="#00D4AA" BorderThickness="0" Padding="10,8" FontSize="13">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value> 
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="PLAYER" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="OfficeInput" Background="#0f3460" Foreground="#DDD" BorderThickness="0" Padding="10,8" FontSize="13">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Add new task -->
        <Border Grid.Row="2" Background="#16213e" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="＋ Add" Click="AddTask_Click"
                        Cursor="Hand" Margin="8,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" CornerRadius="6" Padding="14,8"
                                                Background="#00D4AA" Cursor="Hand">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBox x:Name="NewTaskTextBox" 
                         Background="#0f3460" Foreground="#DDD"
                         BorderThickness="0" Padding="10,8"
                         FontSize="13" FontFamily="Segoe UI"
                         KeyDown="NewTaskTextBox_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- Task list -->
        <Border Grid.Row="3" Background="#16213e" CornerRadius="8" Padding="4">
            <ListView x:Name="TasksListView"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="White"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                                            Margin="0,1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1f2b4d"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Select checkbox -->
                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" 
                                      VerticalAlignment="Center" Margin="0,0,10,0">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <Border x:Name="checkBorder" Width="20" Height="20" 
                                                            CornerRadius="4" BorderThickness="2" 
                                                            BorderBrush="#555" Background="Transparent"
                                                            Cursor="Hand">
                                                        <TextBlock x:Name="checkMark" Text="✓" 
                                                                   Foreground="#00D4AA" FontSize="12"
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center"
                                                                   Visibility="Collapsed"
                                                                   FontWeight="Bold"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="#00D4AA"/>
                                                            <Setter TargetName="checkBorder" Property="Background" Value="#1a3a3a"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>

                            <!-- Task name (editable) -->
                            <TextBox Grid.Column="1" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" 
                                     Foreground="#DDD" FontSize="13" VerticalAlignment="Center"
                                     FontFamily="Segoe UI"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="4,2"/>

                            <!-- Price -->
                            <TextBlock Grid.Column="2" Text="{Binding PriceText}" 
                                       Foreground="#00D4AA" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="8,0"
                                       FontFamily="Segoe UI"/>

                            <!-- Remove button -->
                            <Button Grid.Column="3" Content="✕" 
                                    Click="RemoveTask_Click"
                                    Tag="{Binding}"
                                    Cursor="Hand"
                                    VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Width="26" Height="26" 
                                                            CornerRadius="13" Background="Transparent"
                                                            Cursor="Hand">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#2a1a1a"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="#666"/>
                                        <Setter Property="FontSize" Value="12"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Select all / Deselect all / Global Price -->
        <DockPanel Grid.Row="4" Margin="0,10,0,0">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="Select All" Click="SelectAll_Click" Cursor="Hand"
                        Foreground="#AAA" FontSize="12" FontFamily="Segoe UI" Margin="0,0,10,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" CornerRadius="4" Padding="10,4"
                                                Background="Transparent" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#1f2b4d"/>
                                                <Setter Property="Foreground" Value="#00D4AA"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Deselect All" Click="DeselectAll_Click" Cursor="Hand"
                        Foreground="#AAA" FontSize="12" FontFamily="Segoe UI">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" CornerRadius="4" Padding="10,4"
                                                Background="Transparent" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#1f2b4d"/>
                                                <Setter Property="Foreground" Value="#FF6363"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Global Price Input -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Task Price: $" Foreground="#888" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="GlobalPriceTextBox" 
                         Width="80"
                         Background="#16213e" Foreground="#00D4AA"
                         BorderThickness="0" Padding="8,6"
                         FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"
                         HorizontalContentAlignment="Right">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>
        </DockPanel>

        <!-- Save button -->
        <Button Grid.Row="5" Content="💾  Save" 
                Click="Save_Click"
                Margin="0,12,0,0"
                Padding="0,14"
                FontSize="15"
                FontWeight="SemiBold"
                FontFamily="Segoe UI"
                Cursor="Hand"
                Foreground="White">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="8" Padding="0,14">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00D4AA" Offset="0"/>
                                            <GradientStop Color="#00A88A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
        </Grid>
    </Border>
</Window>
